{
    "rewrites": [
        {
            "source": "/nuke",
            "destination": "/nuke-cache.html"
        },
        {
            "source": "/((?!assets/|sw-sica-v.*\\.js|sw-purge\\.js|workbox-.*\\.js|registerSW\\.js|manifest\\.webmanifest|.*\\.).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(index.html|registerSW.js|manifest.webmanifest|sw-purge.js|sw-sica-v[^/]+\\.js)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
                },
                {
                    "key": "Pragma",
                    "value": "no-cache"
                },
                {
                    "key": "Expires",
                    "value": "0"
                },
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                }
            ]
        }
    ]
}
